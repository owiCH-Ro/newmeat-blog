---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="de">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Mini masthead for articles */
			.mini-masthead {
				text-align: center;
				padding: 1rem 0;
				border-bottom: 1px solid #111;
				margin-bottom: 2rem;
			}
			.mini-masthead a {
				font-family: 'Playfair Display', Georgia, serif;
				font-size: 2rem;
				font-weight: 900;
				color: #111;
				text-decoration: none;
			}
			.mini-masthead a:hover {
				color: var(--accent);
			}

			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 0 1em;
			}

			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				height: auto;
			}

			.article-header {
				text-align: center;
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid #ddd;
			}
			.article-header h1 {
				font-family: 'Playfair Display', Georgia, serif;
				font-size: 2.8rem;
				font-weight: 900;
				line-height: 1.1;
				margin: 0 0 1rem;
			}
			.article-date {
				font-size: 0.9rem;
				color: #666;
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.article-description {
				font-style: italic;
				font-size: 1.2rem;
				color: #444;
				margin-top: 1rem;
			}

			.prose {
				font-family: 'Source Serif 4', Georgia, serif;
				font-size: 1.1rem;
				line-height: 1.8;
				color: #222;
			}
			.prose p {
				margin-bottom: 1.5em;
			}
			.prose h2 {
				font-family: 'Playfair Display', Georgia, serif;
				font-size: 1.8rem;
				margin: 2rem 0 1rem;
			}
			.prose h3 {
				font-family: 'Playfair Display', Georgia, serif;
				font-size: 1.4rem;
				margin: 1.5rem 0 0.8rem;
			}
			.prose ul, .prose ol {
				margin: 1em 0;
				padding-left: 1.5em;
			}
			.prose li {
				margin-bottom: 0.5em;
			}
			.prose blockquote {
				border-left: 3px solid #111;
				padding-left: 1.5em;
				margin: 1.5em 0;
				font-style: italic;
				color: #444;
			}
			.prose a {
				color: var(--accent);
				text-decoration: underline;
			}
			.prose a:hover {
				color: var(--accent-dark);
			}

			/* Back link */
			.back-link {
				display: inline-block;
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid #ddd;
				font-size: 0.9rem;
				color: #666;
			}
			.back-link:hover {
				color: var(--accent);
			}

			@media (max-width: 720px) {
				.article-header h1 {
					font-size: 2rem;
				}
				.prose {
					font-size: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<header class="mini-masthead">
			<a href="/">NEW MEAT</a>
		</header>
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt="" />
					</div>
				)}
				<div class="article-header">
					<p class="article-date">
						<FormattedDate date={pubDate} />
						{updatedDate && <span> · Aktualisiert: <FormattedDate date={updatedDate} /></span>}
					</p>
					<h1>{title}</h1>
					{description && <p class="article-description">{description}</p>}
				</div>
				<div class="prose">
					<slot />
				</div>
				<a href="/" class="back-link">Zurück zur Startseite</a>
			</article>
		</main>
		<Footer />
	</body>
</html>
